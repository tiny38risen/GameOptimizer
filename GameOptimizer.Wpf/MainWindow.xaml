<Window x:Class="GameOptimizer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Optimizer"
        Width="1180"
        Height="760"
        MinWidth="1020"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        FontFamily="Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="TitleBrush" Color="#1E293B" />
        <SolidColorBrush x:Key="BodyBrush" Color="#334155" />
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E8B57" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="15,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="160" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
        </Style>

        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="18" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="Game Optimizer"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TitleBrush}"
                           Margin="0,10,0,40" />

                <Button x:Name="BtnDashboard"
                        Content="■  요약 대시보드"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnDashboard_Click" />
                <Button x:Name="BtnMonitor"
                        Content="~  성능 모니터"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnMonitor_Click" />
                <Button x:Name="BtnSettings"
                        Content="⚙  설정 및 진단"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnSettings_Click" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <TextBlock x:Name="TxtHeaderTitle"
                               Text="시스템 상태 요약"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}" />
                    <TextBlock x:Name="TxtHeaderSub"
                               Text="현재 PC 상태 실시간 확인 중"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="DashboardView"
                              VerticalScrollBarVisibility="Auto"
                              Margin="28">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtHealthScore"
                                               Text="--"
                                               FontSize="48"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TitleBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="종합 최적화 점수"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="20,0">
                                    <TextBlock x:Name="TxtHeroTitle"
                                               Text="최적화가 권장됩니다"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TitleBrush}"
                                               Margin="0,0,0,8" />
                                    <TextBlock x:Name="TxtHeroDesc"
                                               Text="현재 게임이 PC 자원을 얼마나 원활하게 사용하고 있는지 실시간으로 점검하고 성능 향상을 돕습니다."
                                               FontSize="14"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="TxtGameState"
                                               Text="게임 실행 대기 중"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,16,0,0" />
                                    <TextBlock x:Name="TxtStatus"
                                               Text="현재 상태 : 대기"
                                               FontSize="13"
                                               Foreground="{StaticResource BodyBrush}"
                                               Margin="0,6,0,0" />
                                    <TextBlock x:Name="TxtOptimizeState"
                                               Text="최적화 대기 중"
                                               FontSize="13"
                                               Foreground="{StaticResource BodyBrush}"
                                               Margin="0,4,0,0" />
                                    <TextBlock x:Name="TxtRecoveryState"
                                               Text="자동 복구 가능"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <Button x:Name="BtnOptimize"
                                        Grid.Column="2"
                                        Content="최적화 시작"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="BtnOptimize_Click" />
                            </Grid>
                        </Border>

                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <Border Background="White" CornerRadius="16" Margin="0,0,12,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="CPU 쾌적도" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16" />
                                    <ProgressBar x:Name="CpuBar" Value="0" Maximum="100" Margin="0,0,0,12" />
                                    <TextBlock x:Name="CpuDetail" Text="점검 시작 후 표시됩니다" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="16" Margin="12,0,12,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="자원 집중도" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16" />
                                    <ProgressBar x:Name="ThreadBar" Value="0" Maximum="100" Margin="0,0,0,12" />
                                    <TextBlock x:Name="ThreadDetail" Text="점검 시작 후 표시됩니다" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="16" Margin="12,0,0,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="네트워크 반응" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16" />
                                    <ProgressBar x:Name="NetworkBar" Value="0" Maximum="100" Margin="0,0,0,12" />
                                    <TextBlock x:Name="NetworkDetail" Text="점검 시작 후 표시됩니다" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="시스템 권장 조치사항" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,12,0,0" Text="게임 실행 상태 확인" FontWeight="Bold" Foreground="{StaticResource BodyBrush}" />
                                <TextBlock Text="최적화 대상 게임이 정상적으로 실행 중인지 점검합니다." Style="{StaticResource HelpTextStyle}" />
                                <TextBlock Margin="0,12,0,0" Text="안전 적용 모드 유지 권장" FontWeight="Bold" Foreground="{StaticResource BodyBrush}" />
                                <TextBlock Text="게임 도중 문제가 발생하지 않도록 가장 안전한 설정으로 최적화를 유지합니다." Style="{StaticResource HelpTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="MonitorView"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Margin="28">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="성능 모니터링 그래프" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock x:Name="TxtMonitorSummary"
                                           Text="점검 기록 대기 중"
                                           Style="{StaticResource HelpTextStyle}"
                                           Margin="0,8,0,20" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="#F8FAFC" CornerRadius="12" Padding="18" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="CPU (연산 속도)" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" />
                                            <ProgressBar x:Name="CpuMonitorBar" Value="0" Maximum="100" Margin="0,18,0,8" />
                                            <TextBlock Text="게임이 PC 두뇌를 막힘없이 사용하는지 보여줍니다." Style="{StaticResource HelpTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="18" Margin="12,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="네트워크 (반응 속도)" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" />
                                            <ProgressBar x:Name="NetworkMonitorBar" Value="0" Maximum="100" Margin="0,18,0,8" />
                                            <TextBlock Text="서버와의 통신 지연이 없는지 확인합니다." Style="{StaticResource HelpTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Background="#F8FAFC" CornerRadius="12" Padding="18" Margin="0,12,12,0">
                                        <StackPanel>
                                            <TextBlock Text="자원 집중도" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" />
                                            <ProgressBar x:Name="ThreadMonitorBar" Value="0" Maximum="100" Margin="0,18,0,8" />
                                            <TextBlock Text="다른 프로그램의 방해 없이 게임이 우선 처리되는지 보여줍니다." Style="{StaticResource HelpTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="18" Margin="12,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="시스템 안전성" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" />
                                            <ProgressBar x:Name="SafetyMonitorBar" Value="0" Maximum="100" Margin="0,18,0,8" />
                                            <TextBlock Text="문제 발생 시 원래 설정으로 복원될 준비 상태입니다." Style="{StaticResource HelpTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SettingsView"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Margin="28">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="세부 설정 및 진단" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,8,0,18"
                                           Text="처음에는 권장값 그대로 시작해도 됩니다. 궁금한 설정만 펼쳐서 확인하세요."
                                           Style="{StaticResource HelpTextStyle}" />

                                <TextBlock Text="최적화 대상" FontWeight="Bold" Foreground="{StaticResource BodyBrush}" />
                                <DockPanel Margin="0,8,0,14">
                                    <ComboBox x:Name="TargetCombo" Height="34" MinWidth="360" DockPanel.Dock="Left" IsEditable="True" />
                                    <Button x:Name="RefreshButton" Margin="8,0,0,0" Content="목록 새로고침" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshButton_Click" />
                                </DockPanel>
                                <TextBlock x:Name="TxtEnginePath"
                                           Text="시스템 도구 경로 확인 중..."
                                           Style="{StaticResource HelpTextStyle}"
                                           Margin="0,0,0,16" />

                                <TextBlock Text="적용 방식" FontWeight="Bold" Foreground="{StaticResource BodyBrush}" />
                                <WrapPanel Margin="0,8,0,8">
                                    <RadioButton x:Name="DryRunRadio" Margin="0,0,18,8" Content="테스트 모드 (미리보기)" Checked="ModeRadio_Checked" />
                                    <RadioButton x:Name="SoftApplyRadio" Margin="0,0,18,8" Content="안전 적용 모드 (권장)" IsChecked="True" Checked="ModeRadio_Checked" />
                                    <RadioButton x:Name="ApplyRadio" Margin="0,0,18,8" Content="강력 적용 모드" Checked="ModeRadio_Checked" />
                                </WrapPanel>
                                <TextBlock x:Name="TxtModeDescription"
                                           Style="{StaticResource HelpTextStyle}"
                                           Margin="0,0,0,16" />

                                <CheckBox x:Name="ThreadDetailCheck" Content="자원 할당 상세 기록 남기기" Margin="0,0,0,4" />
                                <TextBlock Margin="24,0,0,12" Text="문제 원인을 파악하기 위해 게임이 PC 자원을 어떻게 쓰고 있는지 자세히 기록합니다." Style="{StaticResource HelpTextStyle}" />

                                <CheckBox x:Name="BackgroundDetailCheck" Content="백그라운드 프로그램 상세 기록 남기기" Margin="0,0,0,4" />
                                <TextBlock Margin="24,0,0,12" Text="게임 외에 실행되며 PC를 느리게 만드는 프로그램이 있는지 진단할 때 사용합니다." Style="{StaticResource HelpTextStyle}" />

                                <CheckBox x:Name="LatencyPingCheck" Content="네트워크 상태(핑) 확인" Margin="0,0,0,4" />
                                <TextBox x:Name="LatencyPingText" Text="8.8.8.8" Height="32" Margin="24,0,0,8" />
                                <TextBlock Margin="24,0,0,12" Text="네트워크 끊김 현상이 발생할 때 연결 상태를 점검합니다. 윈도우 설정은 건드리지 않습니다." Style="{StaticResource HelpTextStyle}" />

                                <CheckBox x:Name="BackgroundFilterCheck" Content="예외 프로그램 목록 적용" Margin="0,0,0,4" />
                                <DockPanel Margin="24,0,0,8">
                                    <TextBox x:Name="BackgroundFilterText" Height="32" DockPanel.Dock="Left" MinWidth="360" />
                                    <Button x:Name="BrowseFilterButton" Margin="8,0,0,0" Content="찾기" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseFilterButton_Click" />
                                </DockPanel>
                                <TextBlock Margin="24,0,0,12" Text="최적화 도중 강제로 종료하거나 제한하지 않을 프로그램 목록 파일입니다." Style="{StaticResource HelpTextStyle}" />

                                <CheckBox x:Name="RuntimeLimitCheck" Content="자동 종료 타이머 켜기" Checked="RuntimeLimitCheck_Changed" Unchecked="RuntimeLimitCheck_Changed" Margin="0,0,0,4" />
                                <TextBox x:Name="RuntimeSecondsText" Text="60" Height="32" Width="90" HorizontalAlignment="Left" Margin="24,0,0,8" />
                                <TextBlock x:Name="TxtRuntimeDescription" Margin="24,0,0,16" Style="{StaticResource HelpTextStyle}" />

                                <WrapPanel>
                                    <Button x:Name="EvidenceFolderButton" Content="기록 폴더 열기" Style="{StaticResource SecondaryButtonStyle}" Click="EvidenceFolderButton_Click" />
                                    <Button x:Name="LatestReportButton" Margin="8,0,0,0" Content="최근 진단 리포트 확인" Style="{StaticResource SecondaryButtonStyle}" Click="LatestReportButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="세부 상태 정보" Style="{StaticResource SectionTitleStyle}" />
                                <Expander Header="CPU 상태 분석" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="사용된 주요 코어 수 : 4" Foreground="{StaticResource BodyBrush}" />
                                        <TextBlock Text="현재 처리 속도 : 막힘없이 원활함" Foreground="{StaticResource BodyBrush}" Margin="0,4,0,0" />
                                        <TextBlock Text="Processor Group : 0 / Primary Core : 4 / Fallback Core : 6" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Expander>
                                <Expander Header="자원 집중도 분석" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="게임이 PC 자원을 안정적으로 사용 중입니다." Foreground="{StaticResource BodyBrush}" />
                                        <TextBlock Text="방해 프로그램의 간섭 없음" Foreground="{StaticResource BodyBrush}" Margin="0,4,0,0" />
                                        <TextBlock Text="메인 스레드 ID : 1234 / EMA 점수 : 91 / Migration : 0회" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Expander>
                                <Expander Header="네트워크 연결 분석" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="서버 통신 상태 : 좋음" Foreground="{StaticResource BodyBrush}" />
                                        <TextBlock Text="반응 속도(핑) 변화 : 매우 안정적" Foreground="{StaticResource BodyBrush}" Margin="0,4,0,0" />
                                        <TextBlock Text="RTT : 5ms / RTT 변동 : 1.2ms / DPC 발생 : 0회" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Expander>
                                <Expander Header="안전 시스템 상태" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="최적화 이전 PC 상태 백업 완료" Foreground="{StaticResource BodyBrush}" />
                                        <TextBlock Text="문제 발생 시 자동 복원 준비됨" Foreground="{StaticResource BodyBrush}" Margin="0,4,0,0" />
                                        <TextBlock Text="Affinity 백업 : 완료 / ApplyGuard : 정상 / Rollback 준비 : 완료" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
